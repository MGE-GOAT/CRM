// Nexus CRM — Prisma schema
// Full-featured CRM: contacts, companies, deals pipeline, activities,
// tasks/reminders, tags, roles/permissions, team chat, reporting.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth & people
// ---------------------------------------------------------------------------

enum Role {
  OWNER // full control incl. user management
  ADMIN // manage data + users (except owners)
  MEMBER // standard team member
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MEMBER)
  avatarColor  String   @default("#6366f1")
  isActive     Boolean  @default(true)
  // When the account was deactivated (set on deactivate, cleared on reactivate).
  // A daily job purges accounts deactivated longer than PURGE_DEACTIVATED_DAYS.
  deactivatedAt DateTime?

  // --- Member login approval + work-hours session (owner/admin exempt) ---
  // Set at each MEMBER login; a pending member waits for the owner to approve.
  pendingSince  DateTime?
  // The member's session is valid until this instant (owner sets it on approval,
  // defaulting to 6pm Tehran). Past/null = must (re)request approval to enter.
  approvedUntil DateTime?
  approvedById  String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ownership / assignment relations
  companies        Company[]
  contacts         Contact[]
  deals            Deal[]
  activities       Activity[]
  assignedTasks    Task[]           @relation("TaskAssignee")
  channelMembers   ChannelMember[]
  messages         Message[]
  createdChannels  Channel[]        @relation("ChannelCreator")
  reminders        Reminder[]
  notifications    Notification[]
  createdFactors   Factor[]         @relation("FactorCreator")
  confirmedFactors Factor[]         @relation("FactorConfirmer")
  attendance       Attendance[]
}

// One row per member per day: first clock-in and latest clock-out (Tehran).
// Drives the owner's attendance/activity report.
model Attendance {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day      String // Tehran Gregorian YYYY-MM-DD bucket
  clockIn  DateTime
  clockOut DateTime? // latest logout / auto-logout of the day

  @@unique([userId, day])
  @@index([userId])
  @@index([day])
}

// ---------------------------------------------------------------------------
// On-page notifications (bell + toasts, poll-driven)
// ---------------------------------------------------------------------------

enum NotificationType {
  MESSAGE
  TASK
  REMINDER
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  href      String?
  // Stable source key for dedupe (e.g. a Reminder id for REMINDER notifications).
  sourceId  String?
  read      Boolean          @default(false)
  // Whether the user has actually opened the section this notification links to.
  // Distinct from `read` (acknowledged via «مشاهده شد»): the per-section sidebar
  // badge clears only when the page is visited, never on acknowledgement.
  viewed    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Dedupe key for materialized notifications (e.g. one REMINDER per reminder
  // per user). NULL sourceId rows (MESSAGE/TASK) are unconstrained in Postgres
  // (NULLs compare distinct), so they can repeat freely.
  @@unique([userId, type, sourceId])
  @@index([userId])
  @@index([userId, read, createdAt])
  @@index([userId, viewed])
}

// ---------------------------------------------------------------------------
// CRM core
// ---------------------------------------------------------------------------

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String?
  industry  String?
  senf      String?  // صنف (business/trade category, for filtering)
  website   String?
  phone     String?
  address   String?
  notes     String?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts   Contact[]
  deals      Deal[]
  activities Activity[]
  tags       Tag[]      @relation("CompanyTags")

  @@index([ownerId])
  @@index([name])
}

model Contact {
  id        String   @id @default(cuid())
  firstName  String
  lastName   String
  factorName String? // نام رسمی مشتری روی فاکتور (نامی که خودِ مشتری می‌بیند)
  economicCode       String? // شماره اقتصادی
  nationalId         String? // شناسه/شماره ملی
  registrationNumber String? // شماره ثبت
  postalCode         String? // کد پستی
  email      String?
  phone      String?
  title      String?
  senf      String?  // صنف (business/trade category, for filtering)
  status    String   @default("active")
  notes     String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals      Deal[]
  activities Activity[]
  tasks      Task[]
  reminders  Reminder[]
  factors    Factor[]
  tags       Tag[]      @relation("ContactTags")

  @@index([ownerId])
  @@index([companyId])
  @@index([lastName])
  @@index([createdAt])
  @@index([senf])
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Decimal    @default(0) @db.Decimal(14, 2)
  currency          String     @default("USD")
  stage             DealStage  @default(LEAD)
  status            DealStatus @default(OPEN)
  probability       Int        @default(10)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?
  source            String?    // marketing source / campaign (for attribution)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  tasks      Task[]
  tags       Tag[]      @relation("DealTags")

  @@index([ownerId])
  @@index([stage])
  @@index([status])
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STAGE_CHANGE
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType @default(NOTE)
  content   String
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  contactId String?
  contact   Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([contactId])
  @@index([dealId])
  @@index([companyId])
  @@index([createdAt])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean      @default(false)
  priority    TaskPriority @default(MEDIUM)

  assigneeId String
  assignee   User    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([completed])
  @@index([dueDate])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#64748b")

  contacts  Contact[] @relation("ContactTags")
  companies Company[] @relation("CompanyTags")
  deals     Deal[]    @relation("DealTags")
}

// ---------------------------------------------------------------------------
// Inner team communication (chat)
// ---------------------------------------------------------------------------

model Channel {
  id          String          @id @default(cuid())
  name        String
  description String?
  isDirect    Boolean         @default(false)
  createdById String
  createdBy   User            @relation("ChannelCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  members  ChannelMember[]
  messages Message[]
}

model ChannelMember {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())
  joinedAt   DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}

enum MessageKind {
  NORMAL // ordinary chat message
  TASK_ASSIGN // an assignment card with an acknowledge button
  FACTOR_SHARE // a shared factor card with a link to the factor
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  body      String? // optional: a message may carry only attachment(s)
  createdAt DateTime @default(now())

  // structured message kind + task-assignment acknowledgement
  kind     MessageKind @default(NORMAL)
  taskId   String? // set for TASK_ASSIGN cards (loose ref; task may be deleted)
  factorId String? // set for FACTOR_SHARE cards (loose ref; links to the factor)
  ackedAt  DateTime? // when the recipient acknowledged a TASK_ASSIGN card

  // edit / soft-delete
  editedAt  DateTime?
  deletedAt DateTime? // soft delete — row kept so replies/threads don't break

  // reply / quote
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  attachments Attachment[]

  @@index([channelId, createdAt])
}

// File/image attachments on a message. Bytes live on a mounted volume
// (see storage lib); this row holds the metadata + storage key.
model Attachment {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String // original display name
  mimeType  String
  size      Int // bytes
  storageKey String  @unique // on-disk filename (cuid + ext)
  createdAt DateTime @default(now())

  @@index([messageId])
}

// ---------------------------------------------------------------------------
// Calendar reminders (team-public or personal-private)
// ---------------------------------------------------------------------------

enum ReminderAction {
  GENERAL // a plain reminder
  CALL // call the contact
  WHATSAPP // send the contact a WhatsApp message
  SMS // send the contact an SMS
}

model Reminder {
  id          String         @id @default(cuid())
  title       String
  description String?
  date        DateTime // when the reminder is for (date + time)
  isPublic    Boolean        @default(false) // true = whole team, false = only creator
  color       String         @default("#d4af37")
  done        Boolean        @default(false)

  // outreach: call / whatsapp / sms a specific contact
  action      ReminderAction @default(GENERAL)
  messageBody String? // prefilled text for WhatsApp/SMS
  contactId   String?
  contact     Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // SMS auto-send tracking (only relevant when action = SMS)
  smsStatus   String? // null = not processed | "sent" | "failed" | "skipped"
  smsSentAt   DateTime?
  smsError    String?

  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([date])
  @@index([createdById])
}

// ---------------------------------------------------------------------------
// Factors (فاکتور) — pre-factor → factor lifecycle with per-source sending
// ---------------------------------------------------------------------------

enum PaymentKind {
  CASH // نقدی
  CHEQUE // چکی
  HALF_HALF // نصف نقدی نصف چکی
}

enum FactorState {
  INITIAL // پیش‌فاکتور — awaiting owner's first confirmation (تأیید اولیه)
  FOLLOWING_UP // پیگیری — owner confirmed; creator sends to buyer, then marks paid
  PAID // پرداخت‌شده — becomes a فاکتور; owner-only visibility from here
  SENDING // ارسالی — owner confirmed paid + selected source(s)
  EXIT // خروج — final; archived under the buyer's name
  CANCELED // لغو‌شده — buyer didn't pay after the initial confirmation; terminal
}

// Fixed allowed sending sources; owner enables a subset (see FactorSourceOption).
enum SourceKind {
  IMANZADEH // ایمان‌زاده
  BAFTINEH // بافتینه
  BAFT_IRAN // بافت ایران
  BEH_BAFT // به‌بافت
  ANAHITA // آناهیتا
}

model Factor {
  id     String      @id @default(cuid())
  number Int // شماره فاکتور — sequential per month (see monthKey)
  monthKey String // Jalali year-month bucket, e.g. "1405-04" — numbering + reset
  state  FactorState @default(INITIAL)
  paymentKind PaymentKind @default(CASH)

  // Buyer (مشخصات خریدار) — snapshot + optional live contact link
  contactId    String?
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  buyerName    String
  buyerPhone   String?
  buyerAddress String?
  buyerEconomicCode       String? // شماره اقتصادی
  buyerNationalId         String? // شناسه/شماره ملی
  buyerRegistrationNumber String? // شماره ثبت
  buyerPostalCode         String? // کد پستی

  // Seller (مشخصات فروشنده) — editable defaults, snapshotted per factor
  sellerName      String  @default("اسپان هلدینگ")
  sellerAddress   String  @default("تهران، ۵ خرداد")
  sellerPhone     String  @default("۰۹۱۲۲۶۰۰۸۰۴")
  sellerMobile    String  @default("۰۹۱۲۴۴۸۴۷۴۴")
  sellerInstagram String  @default("@spunholding")
  sellerWebsite   String  @default("www.spunholding.com")

  // Totals (ریال)
  discount Decimal @default(0) @db.Decimal(16, 0)
  vat      Decimal @default(0) @db.Decimal(16, 0)
  notes    String? @default("اعتبار پیش فاکتور درصورت واریز نقدی حداکثر ۴۸ ساعت می‌باشد")

  creatorId   String
  creator     User    @relation("FactorCreator", fields: [creatorId], references: [id])
  confirmedById String?
  confirmedBy   User?  @relation("FactorConfirmer", fields: [confirmedById], references: [id])

  confirmedAt DateTime? // owner's first confirmation (→ FOLLOWING_UP)
  paidAt      DateTime? // creator marked paid (→ PAID)
  sentAt      DateTime? // owner confirmed paid + picked sources (→ SENDING)
  archivedAt  DateTime? // fully checked-out (→ EXIT / archived)
  canceledAt  DateTime? // buyer declined to pay (→ CANCELED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   FactorItem[]
  sources FactorSourceEntry[]

  // Per-source child factors. A "sent" factor with multiple منابع ارسال clones
  // one editable/printable child factor per source. Children carry their own
  // number and are EXCLUDED from the main list, dashboard, reports and monthly
  // counts (always filter `parentFactorId: null` for top-level factors).
  parentFactorId String?
  parent         Factor?     @relation("FactorTree", fields: [parentFactorId], references: [id], onDelete: Cascade)
  children       Factor[]    @relation("FactorTree")
  sourceKind     SourceKind? // which source this child represents (null on top-level)
  childOfEntry   FactorSourceEntry? @relation("EntryChild")

  @@unique([monthKey, number])
  @@index([state])
  @@index([creatorId])
  @@index([contactId])
  @@index([monthKey])
  @@index([parentFactorId])
}

model FactorItem {
  id        String  @id @default(cuid())
  factorId  String
  factor    Factor  @relation(fields: [factorId], references: [id], onDelete: Cascade)
  row       Int // ردیف
  name      String // نام کالا/خدمات
  quantity  Decimal @default(0) @db.Decimal(14, 2) // تعداد/مقدار
  unitPrice Decimal @default(0) @db.Decimal(16, 0) // بهای واحد (ریال)
  description String? // شرح کالا

  @@index([factorId])
}

// One entry per owner-selected source at SENDING. Each is independently
// checkable (→ archived) and printable. Archived when checked by owner/admin.
model FactorSourceEntry {
  id       String     @id @default(cuid())
  factorId String
  factor   Factor     @relation(fields: [factorId], references: [id], onDelete: Cascade)
  source   SourceKind
  checked  Boolean    @default(false) // true = آرشیو; false = در حال انجام
  checkedAt   DateTime?
  checkedById String?

  // The cloned, independently editable/printable factor for this source.
  childFactorId String? @unique
  child         Factor? @relation("EntryChild", fields: [childFactorId], references: [id], onDelete: SetNull)

  @@unique([factorId, source])
  @@index([factorId])
  @@index([checked])
}

// Owner-managed list of enabled sending sources (subset of the fixed 5).
model FactorSourceOption {
  key     SourceKind @id
  enabled Boolean    @default(false)
}

// Persisted end-of-month snapshot. The complete monthly data (per-user
// work-hours + paid-factor counts, the attendance log, and every factor of the
// month with full detail) is stored here as JSON *before* the live rows for
// that month are purged — so nothing is ever lost and the owner can always
// view/download a closed month.
model MonthlyArchive {
  id              String   @id @default(cuid())
  month           String   @unique // Jalali "YYYY-MM"
  payload         Json // full snapshot (see buildMonthArchive)
  factorCount     Int      @default(0)
  attendanceCount Int      @default(0)
  createdById     String?
  createdAt       DateTime @default(now())
}

// Single-row, owner-settable running counter for factor "codes". Lets the team
// align the app's factor numbers with their real invoice sequence (~5000) and
// change the starting point at any time; numbering is continuous (no monthly
// reset) so codes never repeat.
model FactorCounter {
  id   String @id @default("singleton")
  next Int    @default(1) // the number the NEXT factor will receive
}
