# Copy to `.env` on the server, fill in real values, then `docker compose up -d --build`.

# Postgres password (compose builds DATABASE_URL from this)
DB_PASSWORD=use-a-strong-password-here

# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Trust the reverse-proxy (Nginx) X-Forwarded-Host header
AUTH_TRUST_HOST=true

# Public URL — the subdomain
NEXTAUTH_URL=https://crm.spunholding.com

# First-run owner account (created automatically on first container start;
# password is NOT reset on later restarts — change it in-app afterwards)
ADMIN_EMAIL=admin@spunholding.com
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_NAME=مدیر سیستم

# SMS via Melipayamak classic web service (optional — leave empty to disable).
# Uses your panel login. Sender must be a DEDICATED line (خط اختصاصی) for custom text.
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_SENDER=
# Secret for the SMS cron endpoint; generate with: openssl rand -hex 16
CRON_SECRET=
