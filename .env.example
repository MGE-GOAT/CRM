# Database (dedicated Docker Postgres on port 5544)
DATABASE_URL="postgresql://crm:CHANGE_ME@localhost:5544/crm?schema=public"

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
# In production set this to your subdomain, e.g. https://crm.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
